POSTGRES_VERSION=16-alpine
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=keeneye
DB_PORT=5432
BACKEND_PORT=8080
NGINX_PORT=80

GRAFANA_PORT=3300
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

DATABASE_URL=postgres://postgres:postgres@localhost:5432/keeneye?sslmode=disable
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
LOG_LEVEL=info
APP_ENV=development
SEED_DEV_DATA=true
DEV_SEED_PASSWORD=DevPassword1!

REGISTRATION_LINK_TTL=24h
REGISTRATION_BASE_URL=http://localhost
EMAIL_RETRY_BACKEND=worker
KAFKA_BROKERS=kafka:9092
KAFKA_EMAIL_TOPIC=registration-email-retry
KAFKA_CONSUMER_GROUP=registration-email
KAFKA_PORT=9092
EMAIL_RETRY_MAX_ATTEMPTS=5
EMAIL_RETRY_SIMULATE_FAILURE_RATE=0.3
EXPIRATION_WORKER_INTERVAL=30s
EMAIL_RETRY_WORKER_INTERVAL=15s
MAILER_TYPE=log
